APP_NAME="NextDev API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ─────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nextdev
DB_USERNAME=root
DB_PASSWORD=

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_STORE=database
CACHE_PREFIX=nextdev_

# ── Queue ─────────────────────────────────────────────────────────────────────
QUEUE_CONNECTION=database

# ── Mail ──────────────────────────────────────────────────────────────────────
# 'log' writes emails to storage/logs/laravel.log instead of sending them —
# zero setup required for local development on bare PHP (php artisan serve).
#
# If you're running inside Docker with a Mailpit container on the same
# network, switch to:
#   MAIL_MAILER=smtp
#   MAIL_HOST=mailpit
#   MAIL_PORT=1025
#
# If running PHP directly on your host machine (Windows/Mac/Linux, no Docker)
# and you want a real local inbox UI, install Mailpit as a standalone binary
# (https://mailpit.axllent.org) and point MAIL_HOST at 127.0.0.1 instead.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@nextdev.io"
MAIL_FROM_NAME="${APP_NAME}"

# ── Sanctum ───────────────────────────────────────────────────────────────────
# Comma-separated list of domains allowed to make stateful requests
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000
SANCTUM_TOKEN_EXPIRY=43200

# ── CORS (Next.js frontend origins) ──────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Password Reset ────────────────────────────────────────────────────────────
PASSWORD_RESET_EXPIRY=60

# ── File Storage ──────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
